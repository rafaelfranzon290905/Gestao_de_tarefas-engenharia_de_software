generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  email     String    @unique
  nome      String
  senha     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  id        Int       @id @default(autoincrement())
  tarefas   Tarefas[] @relation("UsuarioTarefas")

  @@map("usuarios")
}

model Tarefas {
  titulo    String
  descricao String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  id        Int      @id @default(autoincrement())
  deUsuario Int?
  usuario   Usuario? @relation("UsuarioTarefas", fields: [deUsuario], references: [id])

  @@map("tarefas")
}
